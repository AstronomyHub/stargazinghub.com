---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: string;
  markdownUrl?: string;
  alternateLinks?: Array<{ hreflang: string; path: string }>;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = 'Stargazing Hub: Sky Map, Light Pollution & Aurora Forecast',
  description = 'Plan every night under the stars with a real sky map, stargazing index, light pollution map, aurora forecast, 3D Moon, meteor calendar and astrophotography tools.',
  image = '/images/icon.png',
  lang = 'en',
  markdownUrl,
  alternateLinks,
  structuredData
} = Astro.props;

import { translations } from '../i18n/ui';
import { downloadLinks, homepageAlternateLinks, homepagePaths, siteUrl } from '../data/appKnowledge';
const t = translations[lang as keyof typeof translations] || translations.en;
const siteTitle = title === 'Stargazing Hub - Sky Live'
  ? `${t.brand?.name} - Sky Map & Forecast`
  : title;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const resolvedAlternateLinks = alternateLinks ?? (homepagePaths.has(currentPath) ? homepageAlternateLinks : []);
const markdownAbsoluteUrl = markdownUrl ? new URL(markdownUrl, Astro.site) : null;
const defaultStructuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": t.brand?.name || "Stargazing Hub",
  "alternateName": "天文通",
  "url": siteUrl,
  "operatingSystem": "iOS, Android",
  "applicationCategory": "EducationalApplication",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "description": description,
  "featureList": [
    "Real-time sky map and AR star chart",
    "Stargazing index and multi-model hourly forecast",
    "Light pollution, aurora, Sun, Moon and Milky Way planning maps",
    "Night-sky photo recognition",
    "3D Moon, meteor calendar and astrophotography tools"
  ],
  "sameAs": [downloadLinks.appStore, downloadLinks.googlePlay],
  "downloadUrl": [downloadLinks.appStore, downloadLinks.googlePlay]
};
const structuredDataList = structuredData
  ? Array.isArray(structuredData) ? structuredData : [structuredData]
  : [defaultStructuredData];

import LanguageRedirect from '../components/LanguageRedirect.astro';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/icon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />
    {resolvedAlternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={new URL(link.path, Astro.site)} />
    ))}
    {markdownAbsoluteUrl && (
      <link rel="alternate" type="text/markdown" href={markdownAbsoluteUrl} />
    )}

    <!-- Primary Meta Tags -->
    <title>{siteTitle}</title>
    <meta name="title" content={siteTitle} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={siteTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <!-- Apple Touch Icon -->
    <link rel="apple-touch-icon" sizes="180x180" href="/images/icon.png" />

    <!-- JSON-LD Structured Data for search engines -->
    {structuredDataList.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)}></script>
    ))}
    <!-- Matomo -->
    <script is:inline>
      var _paq = window._paq = window._paq || [];
      /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
      _paq.push(['trackPageView']);
      _paq.push(['enableLinkTracking']);
      (function() {
        var u="//matomotech.com/";
        _paq.push(['setTrackerUrl', u+'matomo.php']);
        _paq.push(['setSiteId', '28']);
        var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
        g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
      })();
    </script>
    <!-- End Matomo -->
  </head>
  <body class="starry-bg">
    <LanguageRedirect />
    <div class="min-h-screen flex flex-col">
      <slot />
    </div>
  </body>
</html>
