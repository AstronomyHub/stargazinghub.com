---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import Testimonials from '../../components/Testimonials.astro';
import DownloadSection from '../../components/DownloadSection.astro';
import CompassPromo from '../../components/CompassPromo.astro';
import Footer from '../../components/Footer.astro';
import { translations } from '../../i18n/ui';

const lang = 'zh-tw';
const t = translations[lang];
---

<Layout title={t.meta?.title || '天文通：星圖、光污染、極光預報與觀星指數'} lang={lang} description={t.meta?.description}>
  <main>
    <Hero t={t} lang={lang} />
    <Features t={t} />
    <Testimonials t={t} />
    <DownloadSection t={t} />
    <CompassPromo lang={lang} />
  </main>
  <Footer t={t} lang={lang} />
</Layout>
