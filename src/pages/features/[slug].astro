---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { featurePages, downloadLinks, siteUrl } from '../../data/appKnowledge';
import { translations } from '../../i18n/ui';

export function getStaticPaths() {
  return featurePages.map((feature) => ({
    params: { slug: feature.slug },
    props: { feature },
  }));
}

const { feature } = Astro.props;
const t = translations.en;
const featureUrl = new URL(`/features/${feature.slug}/`, siteUrl).toString();
const markdownUrl = `/features/${feature.slug}.md`;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: feature.title,
    description: feature.metaDescription,
    url: featureUrl,
    mainEntity: {
      '@type': 'SoftwareApplication',
      name: 'Stargazing Hub',
      applicationCategory: 'EducationalApplication',
      operatingSystem: 'iOS, Android',
      description: feature.citableSummary,
      featureList: feature.capabilities,
      installUrl: [downloadLinks.appStore, downloadLinks.googlePlay],
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: siteUrl,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: feature.shortTitle,
        item: featureUrl,
      },
    ],
  },
];
---

<Layout
  title={`${feature.title} | Stargazing Hub`}
  description={feature.metaDescription}
  lang="en"
  markdownUrl={markdownUrl}
  structuredData={structuredData}
>
  <main class="relative z-10">
    <section class="relative isolate px-6 pt-24 pb-16 overflow-hidden">
      <div class="cosmic-nebula nebula-1 opacity-20"></div>
      <div class="max-w-6xl mx-auto">
        <a href="/" class="inline-flex items-center gap-2 text-sm text-[var(--text-secondary)] hover:text-white transition-colors mb-8">
          <span aria-hidden="true">←</span>
          Stargazing Hub
        </a>

        <div class="grid lg:grid-cols-[1.05fr_0.95fr] gap-10 lg:gap-14 items-start">
          <div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass mb-6">
              <span class="w-2 h-2 rounded-full bg-[var(--oxygen-blue)]"></span>
              <span class="text-sm text-[var(--text-secondary)]">Feature guide</span>
            </div>

            <h1 class="text-[clamp(2.7rem,7vw,5.5rem)] mb-6">
              <span class="gradient-text-cool">{feature.title}</span>
            </h1>

            <p class="text-lg sm:text-xl text-[var(--text-secondary)] max-w-3xl leading-relaxed mb-8">
              {feature.summary}
            </p>

            <div class="flex flex-wrap gap-3">
              <a class="btn-primary no-underline" href={downloadLinks.appStore}>Download on App Store</a>
              <a class="btn-secondary no-underline" href={downloadLinks.googlePlay}>Get it on Google Play</a>
              <a class="btn-secondary no-underline" href={markdownUrl}>Markdown</a>
            </div>
          </div>

          <aside class="glass-card p-6 sm:p-8">
            <p class="text-xs uppercase tracking-[0.2em] text-[var(--text-muted)] mb-4">Citable Summary</p>
            <blockquote class="text-xl sm:text-2xl leading-snug text-white">
              {feature.citableSummary}
            </blockquote>
            <div class="mt-6 flex flex-wrap gap-2">
              {feature.keywords.map((keyword: string) => (
                <span class="text-xs px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-[var(--text-secondary)]">
                  {keyword}
                </span>
              ))}
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="px-6 pb-20">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-3 gap-6">
        <div class="glass-card p-6 sm:p-7">
          <h2 class="text-2xl sm:text-3xl mb-5">Core Capabilities</h2>
          <ul class="space-y-3 text-[var(--text-secondary)]">
            {feature.capabilities.map((item: string) => (
              <li class="flex gap-3">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[var(--hydrogen-pink)] shrink-0"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="glass-card p-6 sm:p-7">
          <h2 class="text-2xl sm:text-3xl mb-5">Use Cases</h2>
          <ul class="space-y-3 text-[var(--text-secondary)]">
            {feature.useCases.map((item: string) => (
              <li class="flex gap-3">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[var(--oxygen-blue)] shrink-0"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="glass-card p-6 sm:p-7">
          <h2 class="text-2xl sm:text-3xl mb-5">Related Tools</h2>
          <ul class="space-y-3 text-[var(--text-secondary)]">
            {feature.relatedTools.map((item: string) => (
              <li class="flex gap-3">
                <span class="mt-2 w-1.5 h-1.5 rounded-full bg-[var(--sulfur-gold)] shrink-0"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </main>
  <Footer t={t} lang="en" />
</Layout>
