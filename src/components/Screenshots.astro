---
import { Image } from 'astro:assets';
import googleplayScreenshotsConfig from '../googleplay-screenshots.config.json';

interface ScreenshotMeta {
  alt: string;
  title: string;
  description: string;
}

const screenshotMeta: ScreenshotMeta[] = [
  {
    alt: 'Stargazing Hub home screen with stargazing index, sunrise and sunset glow forecast, Moon phase, and hourly conditions',
    title: 'Stargazing Index and Golden Hour Forecast',
    description: 'Check whether tonight is worth going out before you pack your gear'
  },
  {
    alt: 'Night sky photo recognition result screen showing identified stars and constellation information',
    title: 'Night Sky Photo Recognition',
    description: 'Take a photo of the sky and resolve the real star field'
  },
  {
    alt: 'Real star chart screen with visible constellations, Milky Way simulation, horizon, and framing tools',
    title: 'Real Sky Map and AR Star Chart',
    description: 'Simulate the sky with constellations, horizon, satellites, Milky Way and framing overlays'
  },
  {
    alt: 'Planning map screen with light pollution layer and night-sky planning overlays',
    title: 'Light Pollution and Planning Maps',
    description: 'Choose better sites using light pollution, weather, aurora, Sun, Moon and Milky Way layers'
  },
  {
    alt: 'Aurora forecast detail page showing readiness information and forecast data',
    title: 'Aurora Alerts and Details',
    description: 'See aurora forecasts early and know when conditions are worth watching'
  },
];

interface Props {
  t: any;
  lang?: string;
}

const { t, lang = 'en' } = Astro.props;

const allScreenshots = import.meta.glob<{ default: ImageMetadata }>('/src/assets/screenshots/**/*.{webp,png,jpg}', { eager: true });
const gpConfig =
  googleplayScreenshotsConfig[lang as keyof typeof googleplayScreenshotsConfig] ||
  googleplayScreenshotsConfig.en;

const getScreenshotImage = (imagePath: string) => allScreenshots[imagePath]?.default;

const screenshots = gpConfig.files
  .slice(0, screenshotMeta.length)
  .map((imagePath, index) => ({
    ...screenshotMeta[index],
    imagePath,
    src: getScreenshotImage(imagePath),
  }))
  .filter((screenshot) => screenshot.src);
const screenshotCount = screenshots.length;
---

<!-- JSON-LD 结构化数据 for SEO -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": t.brand?.name || "Stargazing Hub",
  "applicationCategory": "EducationalApplication",
  "operatingSystem": "iOS, Android",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "screenshot": screenshots.map(s => s.src?.src).filter(Boolean),
  "featureList": [
    "Stargazing index and multi-model hourly forecast",
    "Night sky photo recognition",
    "Real sky map and AR star chart",
    "Light pollution and planning maps",
    "Aurora, meteor, Moon and astrophotography tools"
  ]
}, null, 2)}></script>

<section class="relative py-20 px-6 overflow-hidden">
  <!-- 背景星云 -->
  <div class="absolute inset-0 overflow-hidden max-w-full">
    <div class="cosmic-nebula nebula-2" style="bottom: -5%; right: -5%; opacity: 0.15;"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto">
    <!-- 区域标题 -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 md:px-4 md:py-2 rounded-full glass mb-6 max-w-full">
        <svg class="w-3.5 h-3.5 md:w-4 md:h-4 text-[var(--hydrogen-pink)] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
        </svg>
        <span class="text-xs md:text-sm text-[var(--text-secondary)] truncate">App Preview</span>
      </div>

      <h2 class="mb-4">
        <span class="gradient-text-warm">Beautiful & Intuitive</span>
      </h2>
      <p class="text-[var(--text-secondary)] max-w-2xl mx-auto">
        Designed for clarity and simplicity. Everything you need at your fingertips.
      </p>
    </div>

    <!-- 截图轮播 -->
    <div class="relative max-w-4xl mx-auto">
      <!-- 主截图展示 -->
      <div class="relative">
        <!-- 发光效果 -->
        <div class="absolute inset-0 bg-gradient-to-r from-[var(--hydrogen-pink)] via-[var(--carbon-purple)] to-[var(--nitrogen-cyan)] rounded-[2.5rem] blur-3xl opacity-20"></div>

        <!-- 手机边框 -->
        <div class="relative glass-strong rounded-[2.5rem] p-3 animate-float">
          <div class="bg-[var(--cosmic-void)] rounded-[2rem] overflow-hidden aspect-[9/16] relative">
            <!-- 刘海 -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-28 h-6 bg-black rounded-b-2xl z-20"></div>

            <!-- 截图轮播 -->
            <div class="relative w-full h-full" id="screenshot-carousel">
              {
                screenshots.map((screenshot, index) => (
                    <div
                      class={`absolute inset-0 transition-opacity duration-500 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
                      style={`animation-delay: ${index * 0}s;`}
                      id={`screenshot-${index}`}
                    >
                      <Image
                        src={screenshot.src}
                        alt={screenshot.alt}
                        title={screenshot.title}
                        class="w-full h-full object-cover"
                        loading="lazy"
                        data-description={screenshot.description}
                      />
                    </div>
                  ))
                }
              </div>

            <!-- 轮播指示器 -->
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-20">
              {
                screenshots.map((screenshot, index) => (
                  <button
                    class={`w-2 h-2 rounded-full transition-all duration-300 ${index === 0 ? 'bg-white w-6' : 'bg-white/40 hover:bg-white/60'}`}
                    aria-label={`View ${screenshot.title}: ${screenshot.description}`}
                    title={screenshot.title}
                    onclick={`showScreenshot(${index})`}
                  ></button>
                ))
              }
            </div>
          </div>
        </div>

        <!-- 装饰元素 -->
        <div class="absolute -top-6 -right-6 w-12 h-12 bg-[var(--sulfur-gold)] rounded-full blur-xl opacity-40 animate-float" style="animation-delay: 1s;"></div>
        <div class="absolute -bottom-6 -left-6 w-16 h-16 bg-[var(--oxygen-blue)] rounded-full blur-xl opacity-30 animate-float" style="animation-delay: 2s;"></div>
      </div>
    </div>

    <!-- 特性列表 -->
    <div class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-4 max-w-4xl mx-auto">
      <div class="glass-card p-4 text-center">
        <div class="text-2xl mb-1">🛰️</div>
        <div class="text-xs text-[var(--text-secondary)]">Sky Map</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-2xl mb-1">🌤️</div>
        <div class="text-xs text-[var(--text-secondary)]">Stargazing Forecast</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-2xl mb-1">🌠</div>
        <div class="text-xs text-[var(--text-secondary)]">Aurora & Meteors</div>
      </div>
      <div class="glass-card p-4 text-center">
        <div class="text-2xl mb-1">⭐</div>
        <div class="text-xs text-[var(--text-secondary)]">Astro Tools</div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ screenshotCount }}>
  let currentScreenshot = 0;
  const totalScreenshots = screenshotCount;

  function showScreenshot(index) {
    // Hide all
    for (let i = 0; i < totalScreenshots; i++) {
      const el = document.getElementById(`screenshot-${i}`);
      if (el) {
        el.classList.remove('opacity-100');
        el.classList.add('opacity-0');
      }
    }

    // Show selected
    const selected = document.getElementById(`screenshot-${index}`);
    if (selected) {
      selected.classList.remove('opacity-0');
      selected.classList.add('opacity-100');
    }

    // Update indicators
    const buttons = document.querySelectorAll('#screenshot-carousel button');
    buttons.forEach((btn, i) => {
      if (i === index) {
        btn.className = 'w-2 h-2 rounded-full transition-all duration-300 bg-white w-6';
      } else {
        btn.className = 'w-2 h-2 rounded-full transition-all duration-300 bg-white/40 hover:bg-white/60';
      }
    });

    currentScreenshot = index;
  }

  // Auto-advance
  setInterval(() => {
    currentScreenshot = (currentScreenshot + 1) % totalScreenshots;
    showScreenshot(currentScreenshot);
  }, 4000);
</script>
