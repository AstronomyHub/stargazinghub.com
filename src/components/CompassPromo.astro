---
// 首页"姊妹 App"入口:链到 Compass Altimeter 产品页(本地化)
import { getCompass, compassPath } from '../data/compassContent';

interface Props { lang: string }
const { lang } = Astro.props;
const c = getCompass(lang);
const label = c.title.split(/[:：·—]/)[0].trim();
const href = compassPath(lang);
---

<section class="px-6 py-10">
  <div class="max-w-5xl mx-auto">
    <a
      href={href}
      class="glass-card group flex items-center gap-5 p-6 md:p-7"
      style="text-decoration:none;"
    >
      <img
        src="/compass/icon.png"
        alt={label}
        width="64"
        height="64"
        class="flex-shrink-0 rounded-2xl"
        style="width:64px;height:64px;box-shadow:0 8px 24px rgba(255,194,75,0.18);"
      />
      <div class="min-w-0 flex-1">
        <span class="text-xs font-medium text-[var(--sulfur-gold)]">{c.eyebrow}</span>
        <h3 class="mt-0.5 mb-1 text-lg md:text-xl font-bold text-white">{label}</h3>
        <p class="text-sm text-[var(--text-muted)] leading-relaxed">{c.subtitle}</p>
      </div>
      <span
        class="flex-shrink-0 text-2xl text-[var(--text-muted)] transition-all group-hover:text-[var(--hydrogen-pink)] group-hover:translate-x-1"
        aria-hidden="true"
      >→</span>
    </a>
  </div>
</section>
